{
  "expo": {
    "name": "Visby",
    "slug": "visby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "visby",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.visby.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Visby needs your location to collect stamps and discover nearby places.",
        "NSPhotoLibraryUsageDescription": "Visby needs access to your photos to add pictures to stamps and food logs.",
        "NSCameraUsageDescription": "Visby needs camera access to take photos for your collection."
      },
      "buildNumber": "4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDFBF8"
      },
      "package": "com.visby.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "Visby needs access to your photos to add pictures to your collection."
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "38b552ec-1377-4799-ae78-b611c005d42a"
      }
    },
    "owner": "sisterser"
  }
}
